---
import { normalizeHost } from "../lib/host";
import { resolveListing } from "../lib/domains";
import { getEnv } from "../lib/runtime";
import Lander from "../components/Lander.astro";

// Per-request SSR: this page is never prerendered, so the Host header is real.
export const prerender = false;

const host = normalizeHost(Astro.request);
const listing = resolveListing(host);

// status "hidden" => not publicly listed. Return a 404.
if (listing.status === "hidden") {
  return new Response("Not found", { status: 404 });
}

const env = getEnv(Astro.locals);
const defaultBuyUrl = env.DEFAULT_BUY_URL;

// Per-domain metadata so shared links preview as "<domain> is for sale".
const sold = listing.status === "sold";
const title = sold
  ? `${listing.domain} — sold`
  : `${listing.domain} is for sale`;
const description = sold
  ? `${listing.domain} has been sold.`
  : `The domain ${listing.domain} is for sale. Make an offer or buy it now.`;
const canonical = `https://${listing.domain}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Twitter: correct per-domain preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="robots" content="index, follow" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%235b71f0'/%3E%3C/svg%3E"
    />

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        -webkit-text-size-adjust: 100%;
      }
      body {
        margin: 0;
        min-height: 100dvh;
        background: var(--bg);
        color: var(--fg);
        font-family:
          system-ui,
          -apple-system,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <Lander listing={listing} defaultBuyUrl={defaultBuyUrl} />
  </body>
</html>
