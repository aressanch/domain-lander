# ---------------------------------------------------------------------------
# domain-lander environment
# Copy to .dev.vars (local Cloudflare dev) or set as Pages project secrets.
# Only PUBLIC_* values are exposed to the browser; everything else is server-only.
# ---------------------------------------------------------------------------

# --- Email: Resend (default provider) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Where offer leads are emailed. Also used as the From unless RESEND_FROM is set.
NOTIFY_EMAIL=you@example.com
# Optional verified From address for Resend (defaults to onboarding@resend.dev).
RESEND_FROM="Domain Offers <offers@yourdomain.com>"

# --- Email: AWS SES (alternative provider) ---
# If SES_ACCESS_KEY_ID + SES_SECRET_ACCESS_KEY are set, SES is used instead of Resend.
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_REGION=us-east-1
# Verified SES sender identity (required when using SES).
SES_FROM=offers@yourdomain.com

# --- Bot protection: Cloudflare Turnstile ---
TURNSTILE_SECRET=0x4xxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_TURNSTILE_SITE_KEY=0x4xxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: Cockpit webhook (also receives each lead as JSON) ---
COCKPIT_WEBHOOK_URL=
COCKPIT_TOKEN=

# --- Optional: PostHog analytics (offer_submitted event) ---
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Optional: default external Buy Now link when a listing omits buyUrl ---
DEFAULT_BUY_URL=

# ---------------------------------------------------------------------------
# Onboarding script only (scripts/add-domains.ts) — NOT needed at runtime.
# ---------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# The Pages project these custom domains attach to.
CLOUDFLARE_PAGES_PROJECT=domain-lander
